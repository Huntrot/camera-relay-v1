# =============================================================================
#  SERVER CONFIG — V1 (Render Web Service)
#  Hướng dẫn: Bạn không cần upload file này lên Render.
#  Thay vào đó, cấu hình các biến này trực tiếp tại tab "Environment" trên Render dashboard.
# =============================================================================

# ─── Server (Mặc định do Render tự cấu hình cổng) ─────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Bảo mật (Cấu hình trên Render Dashboard) ─────────────────────────────────
# API_KEY=your-secret-key-here

# ─── TURN Server (Thêm trên Render Dashboard nếu cần hỗ trợ NAT vượt tường lửa) ──
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=
